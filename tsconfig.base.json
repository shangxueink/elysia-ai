{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@elysia-ai/core": ["packages/core/src"],
      "koishi-plugin-elysia-ai-runtime": ["packages/runtime/src"],
      "koishi-plugin-elysia-ai-body": ["packages/body/src"],
      "@elysia-ai/behavior": ["packages/behavior/src"],
      "@elysia-ai/brain": ["packages/brain/src"],
      "@elysia-ai/model-gateway": ["packages/model-gateway/src"]
    }
  }
}
